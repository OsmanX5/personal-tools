# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Password to access the app (simple single-user auth)
APP_PASSWORD=change-me

# Secret for encrypting session cookies (min 32 characters)
SESSION_SECRET=replace_with_a_random_string_at_least_32_chars
